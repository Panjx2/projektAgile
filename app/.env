env:
  - name: PORT
    value: "8080"
  - name: SPRING_DATASOURCE_URL
    value: "jdbc:postgresql://postgres-service:5432/app"
  - name: SPRING_DATASOURCE_USERNAME
    value: "postgres"
  - name: SPRING_DATASOURCE_PASSWORD
    value: "postgres"
  - name: SPRING_SECURITY_USER_NAME
    value: "admin"
  - name: SPRING_SECURITY_USER_PASSWORD
    value: "admin"